<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fisioportal | Comunidad de Fisioterapia</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap');
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .hidden-section { display: none; }
        .active-link { background-color: #f1f5f9; color: #0f172a; }
        .card-friendly { transition: transform 0.2s ease, box-shadow 0.2s ease; }
        .card-friendly:hover { transform: translateY(-2px); box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1); }
    </style>
</head>
<body class="bg-[#F9FBFC] text-slate-800">

    <nav class="sticky top-0 bg-white/80 backdrop-blur-md border-b border-slate-100 z-50">
        <div class="max-w-5xl mx-auto px-6 h-20 flex justify-between items-center">
            <div class="flex items-center gap-2">
                <div class="w-8 h-8 bg-teal-600 rounded-lg flex items-center justify-center text-white font-bold">F</div>
                <span class="text-xl font-extrabold tracking-tight text-slate-900">FISIOPORTAL</span>
            </div>
            
            <div class="flex bg-slate-100 p-1 rounded-2xl">
                <button onclick="showSection('noticias')" id="link-noticias" class="nav-link active-link px-4 py-2 text-sm font-bold rounded-xl transition-all">Radar Fisio</button>
                <button onclick="showSection('empleo')" id="link-empleo" class="nav-link px-4 py-2 text-sm font-bold text-slate-500 rounded-xl transition-all hover:text-slate-900">Empleo</button>
                <button onclick="showSection('proyecto')" id="link-proyecto" class="nav-link px-4 py-2 text-sm font-bold text-slate-500 rounded-xl transition-all hover:text-slate-900">Proyecto</button>
            </div>
        </div>
    </nav>

    <main class="max-w-5xl mx-auto px-6 py-12">

        <div id="section-noticias" class="content-section">
            <div class="mb-10 text-center">
                <h2 class="text-3xl font-extrabold text-slate-900">Radar Fisio</h2>
                <p class="text-slate-500 mt-2">La actualidad que impacta en nuestra profesión.</p>
            </div>
            <div id="news-grid" class="max-w-lg mx-auto">
                </div>
        </div>

        <div id="section-empleo" class="content-section hidden-section">
            <div class="bg-teal-50 border border-teal-100 p-10 rounded-[2.5rem] text-center">
                <h3 class="text-2xl font-bold text-teal-900">Buscamos ofertas dignas</h3>
                <p class="text-teal-800/70 mt-4 max-w-lg mx-auto">Estamos validando convenios para asegurar que cada oferta aquí sea respetuosa. Próximamente.</p>
            </div>
        </div>

        <div id="section-proyecto" class="content-section hidden-section pt-10">
            <div class="mb-16 border-l-4 border-teal-600 pl-6">
                <h3 class="text-4xl font-black text-slate-900 tracking-tight">Los pilares de Fisioportal</h3>
                <p class="text-slate-600 mt-2 text-lg italic font-medium">Todo lo que ves aquí es de acceso abierto.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
                <div class="bg-white p-8 rounded-[2.5rem] border border-slate-100 shadow-sm card-friendly">
                    <div class="w-12 h-12 bg-slate-50 rounded-2xl flex items-center justify-center mb-6 text-2xl">⚖️</div>
                    <h4 class="text-xl font-bold text-slate-900 mb-4">Tendencia Horizontal</h4>
                    <p class="text-slate-700 leading-relaxed text-sm">No creemos en jerarquías estancas. En Fisioportal, cada miembro es una pieza clave y sus propuestas tienen un valor real para la comunidad.</p>
                </div>
                <div class="bg-white p-8 rounded-[2.5rem] border border-slate-100 shadow-sm card-friendly">
                    <div class="w-12 h-12 bg-slate-50 rounded-2xl flex items-center justify-center mb-6 text-2xl">💎</div>
                    <h4 class="text-xl font-bold text-slate-900 mb-4">Transparencia Ética</h4>
                    <p class="text-slate-700 leading-relaxed text-sm">Somos independientes: somos transparentes ante cualquier conflicto de interés. Solo aceptaremos publicidad de marcas éticas.</p>
                </div>
                <div class="bg-white p-8 rounded-[2.5rem] border border-slate-100 shadow-sm card-friendly">
                    <div class="w-12 h-12 bg-slate-50 rounded-2xl flex items-center justify-center mb-6 text-2xl">🔓</div>
                    <h4 class="text-xl font-bold text-slate-900 mb-4">Acceso Libre</h4>
                    <p class="text-slate-700 leading-relaxed text-sm">El conocimiento no es un privilegio. Facilitamos el acceso a la evidencia científica y a las normativas que nos afectan.</p>
                </div>
            </div>

            <div class="p-10 text-center bg-white border border-slate-100 rounded-[2.5rem]">
                <p class="text-2xl font-bold text-slate-800 leading-tight">
                    "Por la fisioterapia de ayer, por la de hoy y sobre todo por la de mañana."
                </p>
            </div>
        </div>
    </main>

    <footer class="py-12 text-center text-slate-400 text-xs font-medium uppercase tracking-widest">
        Fisioportal © 2026 · Hecho con ❤️ para fisioterapeutas
    </footer>

    <script>
        const noticias = [
            {
                tag: "Oportunidad Histórica",
                color: "bg-teal-50 text-teal-600",
                titulo: "La oportunidad de los fisioterapeutas en la regulación de las profesiones sanitarias",
                desc: "Analizamos por qué el nuevo marco legal del Ministerio de Sanidad es una oportunidad histórica para el sector y cómo tu participación puede cambiarlo todo.",
                link: "noticialey.html",
                imagen: "noticia1.jpg"
            }
        ];

        function renderNews() {
            const grid = document.getElementById('news-grid');
            if (!grid) return;
            grid.className = "max-w-lg mx-auto"; 
            grid.innerHTML = noticias.map(n => `
                <article onclick="window.location.href='${n.link}'" class="group bg-white rounded-[2.5rem] border border-slate-100 shadow-xl shadow-slate-200/50 flex flex-col overflow-hidden transition-all duration-300 hover:shadow-2xl hover:-translate-y-1 cursor-pointer">
                    <div class="w-full h-72 md:h-96 overflow-hidden bg-white flex items-center justify-center">
                        <img src="${n.imagen}" alt="Noticia" class="w-full h-full object-contain transition-transform duration-500 group-hover:scale-105">
                    </div>
                    <div class="p-8 pt-4">
                        <div class="mb-4"><span class="${n.color} text-[10px] font-extrabold px-3 py-1 rounded-full uppercase tracking-wider">${n.tag}</span></div>
                        <h3 class="text-2xl md:text-3xl font-black text-slate-900 leading-tight mb-4 group-hover:text-teal-600 transition-colors">${n.titulo}</h3>
                        <p class="text-slate-500 leading-relaxed text-sm mb-8">${n.desc}</p>
                        <div class="flex items-center text-teal-600 font-bold text-sm">
                            <span>Leer análisis y participar</span>
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                        </div>
                    </div>
                </article>
            `).join('');
        }

        // ESTA ES LA FUNCIÓN QUE FALTABA
        function showSection(sectionId) {
            document.querySelectorAll('.content-section').forEach(s => s.classList.add('hidden-section'));
            document.getElementById('section-' + sectionId).classList.remove('hidden-section');
            
            document.querySelectorAll('.nav-link').forEach(l => {
                l.classList.remove('active-link');
                l.classList.add('text-slate-500');
            });
            const btn = document.getElementById('link-' + sectionId);
            if(btn) {
                btn.classList.add('active-link');
                btn.classList.remove('text-slate-500');
            }
        }

        renderNews();
    </script>
</body>
</html>
